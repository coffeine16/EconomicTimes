# Frontend environment — copy to .env.local for dev, set in Vercel for prod.

# The read-only FastAPI backend (hotspots, fusion, memos, etc.). If unreachable,
# the app falls back to the static JSON in public/data/ (demo insurance).
NEXT_PUBLIC_API_URL=http://localhost:8000

# The n8n citizen-report webhook (the channel layer, live over HTTPS). The report
# form POSTs here; n8n validates, canonicalises the ward, and writes to Supabase.
# NOT the FastAPI backend — channels are dumb, agents are smart.
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://aq-intel.duckdns.org/webhook/citizen-report
