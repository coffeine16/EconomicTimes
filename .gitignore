__pycache__/
*.pyc
data/raw/*.parquet
data/outputs/*
!data/samples/
# Local per-city run cache (parquets + logs) — regenerated by run_pipeline.py per
# city, snapshotted by scripts/city_summary.py. Large, machine-local, never committed.
data/outputs_snapshots/
.env
.venv/
.vscode/

# MCP config carries the n8n API key literally (env-var indirection breaks:
# the VS Code process tree holds a stale setx'd N8N_API_KEY it would expand).
.mcp.json

# Credentials. NEVER commit these.
# The GCP service-account JSON is a live private key: leaking it lets anyone bill
# our project. If one is ever pushed, REVOKE it in the console — deleting the
# commit is not enough, it is already in the history and in anyone's clone.
secrets/
*-service-account.json
*.pem

# Terraform (state records resource details; never commit it)
*.tfstate
*.tfstate.*
.terraform/
*.tfplan
